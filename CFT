            p.Btn.Size = UDim2.new(0, (68 + (sA * 18)) * p.Proxy.Value, 0, (68 + (sA * 18)) * p.Proxy.Value)
            p.Btn.Position = UDim2.new(Core.Position.X.Scale, Core.Position.X.Offset + (math.cos(angle)*dist), Core.Position.Y.Scale, Core.Position.Y.Offset + (sA*dist*0.45))
        end
    end
    if CategoryPanel.Visible then
        for _, s in ipairs(StaticStars) do
            local nX = s.Frame.Position.X.Scale - (s.Speed * dt)
            s.Frame.Position = UDim2.new(nX < 0 and 1 or nX, 0, s.Frame.Position.Y.Scale, 0)
        end
    end
end)

