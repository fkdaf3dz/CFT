local function ServerHop()
    local queueEvent = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
    if queueEvent then
        queueEvent('loadstring(game:HttpGet("https://raw.githubusercontent.com/fkdaf3dz/CFT/refs/heads/main/CFT"))()')
        warn("🔄 HIVE: Loadstring queued for next server.")
    else
        warn("⚠️ HIVE: queue_on_teleport not supported by this executor. Script will not auto-run on hop.")
    end

    task.spawn(function()
        while _G.Hive.Running do
            local success, result = pcall(function() return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")) end)
            if success and result and result.data then
                local validServers = {}
                for _, server in ipairs(result.data) do
                    if server.playing < server.maxPlayers - 1 and server.id ~= game.JobId then table.insert(validServers, server) end
                end
                if #validServers > 0 then
                    local targetServer = validServers[math.random(1, #validServers)]
                    warn("🚀 HIVE: Evading to Server ID: " .. string.sub(targetServer.id, 1, 8) .. "...")
                    local tpSuccess, tpError = pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, LocalPlayer) end)
                    if not tpSuccess then warn("⚠️ HIVE TP Error: " .. tostring(tpError)) end
                else
                    warn("⚠️ HIVE: No open servers found. Retrying...")
                end
            else
                warn("⚠️ HIVE: Roblox API Rate Limit hit. Waiting to retry...")
            end
            task.wait(4)
        end
    end)
end

