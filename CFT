    local targetPos = OrbitActive and UDim2.new(0.5, 0, 0.48, 0) or BasePos
    Core.Position = Core.Position:Lerp(UDim2.new(targetPos.X.Scale, targetPos.X.Offset, targetPos.Y.Scale, targetPos.Y.Offset + math.sin(t*2)*10), dt*10)
