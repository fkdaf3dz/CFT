local lastInvSippa, lastVisSippa, lastReward = 0, 0, 0
task.spawn(function()
    while _G.Hive.Running do
        task.wait(0.1)
        local t = tick()
        
        -- 1. BOX UPGRADER (Direct CFrame Teleport after 2.7s)
        if _G.Hive.BoxUpgrader and _G.Hive.MyTycoon then
            local boxes = _G.Hive.MyTycoon:FindFirstChild("FullBoxes", true)
            local machine = _G.Hive.MyTycoon:FindFirstChild("Colorizer1", true)
            local upTarget = machine and machine:FindFirstChild("UpgradePart")
            if boxes and upTarget then
                for _, b in pairs(boxes:GetChildren()) do
                    if not b:GetAttribute("HiveTracked") then
                        b:SetAttribute("HiveTracked", true) 
                        task.spawn(function()
                            task.wait(2.7) 
                            local p = b:IsA("BasePart") and b or b:FindFirstChildWhichIsA("BasePart", true)
                            if p and p.Parent and _G.Hive.BoxUpgrader then
                                p.CFrame = upTarget.CFrame
                                firetouchinterest(p, upTarget, 0); task.wait(0.05); firetouchinterest(p, upTarget, 1)
                            end
                        end)
                    end
                end
            end
        end
        
        -- 2. AUTO-SELL (With 5s Delay)
        if _G.Hive.AutoSellEnabled and _G.Hive.MyTycoon then
            local boxes = _G.Hive.MyTycoon:FindFirstChild("FullBoxes", true)
            if boxes and #boxes:GetChildren() >= _G.Hive.AutoSellLimit and not _G.Hive.IsSelling then
                _G.Hive.IsSelling = true
                task.spawn(function()
                    task.wait(5) -- Waits 5s for the last boxes to finish Colorizer
                    if _G.Hive.AutoSellEnabled then SellAllBoxes(_G.Hive.MyTycoon) end
                    _G.Hive.IsSelling = false
                end)
            end
        end
        
        -- 3. HOURLY REWARDS (RemoteFunction FIX)
        if _G.Hive.HourlyReward and (t - lastReward >= 10) then
            local remote = game:GetService("ReplicatedStorage"):FindFirstChild("ClaimHourlyReward")
            if remote then
                if remote:IsA("RemoteFunction") then
                    task.spawn(function() pcall(function() remote:InvokeServer() end) end)
                elseif remote:IsA("RemoteEvent") then
                    remote:FireServer()
                end
            end
            lastReward = tick()
        end

        -- 4. AUTO UPGRADE HUD
        if _G.Hive.AutoUpgrade then
            local shop = LocalPlayer.PlayerGui:FindFirstChild("TheUI")
            if shop then
                local tycoonFrame = shop:FindFirstChild("tycoonFrame", true)
                if tycoonFrame and tycoonFrame.Visible then
                    local scroll = tycoonFrame:FindFirstChild("ScrollingFrame", true)
                    if scroll then
                        for _, btn in pairs(scroll:GetDescendants()) do
                            if (btn.Name:lower():find("buy") or btn.Name == "Button") and btn:IsA("GuiButton") and btn.Visible then
                                if getconnections then for _, c in pairs(getconnections(btn.MouseButton1Click)) do c:Fire() end end
                            end
                        end
                    end
                end
            end
        end

        -- 5. SIPPAS
        if _G.Hive.InvisibleSippa and (t - lastInvSippa >= 0.8) then
            local bp, ch = LocalPlayer.Backpack, LocalPlayer.Character
            local cola = bp:FindFirstChild("BloxyCola") or (ch and ch:FindFirstChild("BloxyCola"))
            if cola and ch then cola.Parent = ch; cola:Activate(); cola.Parent = bp; lastInvSippa = tick() end
        end
        if _G.Hive.VisibleSippa and (t - lastVisSippa >= 0.8) then
            local bp, ch = LocalPlayer.Backpack, LocalPlayer.Character
            local cola = bp:FindFirstChild("BloxyCola") or (ch and ch:FindFirstChild("BloxyCola"))
            if cola and ch then cola.Parent = ch; cola:Activate(); task.delay(0.8, function() cola:Deactivate() end); lastVisSippa = tick() end
        end
        
        -- 6. BOT KILLER
        if _G.Hive.BotKill and _G.Hive.MyTycoon then
            local npcs = _G.Hive.MyTycoon:FindFirstChild("ActiveNpcs", true)
            local tool = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(_G.Hive.GunName)) or LocalPlayer.Backpack:FindFirstChild(_G.Hive.GunName)
            if tool and npcs then
                for _, n in pairs(npcs:GetChildren()) do
                    local h, hum = n:FindFirstChild("Head"), n:FindFirstChildWhichIsA("Humanoid")
                    if h and hum and hum.Health > 0 then game.ReplicatedStorage.GunFire:FireServer(tool.Name, tool, h.Position, h.Position, h) end
                end
            end
        end
        
        -- 7. AIRDROP GHOST TP (Anti-Cheat Bypass)
        if _G.Hive.AirdropSniper and LocalPlayer.Character then
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local nodes = workspace:FindFirstChild("AirdropNodes")
            if hrp and nodes then
                for _, prompt in pairs(nodes:GetDescendants()) do
                    if prompt:IsA("ProximityPrompt") and prompt.Enabled and prompt.Parent and prompt.Parent:IsA("BasePart") then
                        local origCFrame = hrp.CFrame
                        hrp.Anchored = true -- Prevents velocity spikes
                        hrp.CFrame = prompt.Parent.CFrame + Vector3.new(0, 3, 0)
                        task.wait(0.2)
                        fireproximityprompt(prompt)
                        task.wait(0.2)
                        hrp.CFrame = origCFrame
                        hrp.Anchored = false
                        task.wait(5) 
                    end
                end
            end
        end
    end
end)

